# Modèle LLM servi par Ollama (doit être déjà téléchargé : ollama pull <modele>)
# qwen2.5:1.5b choisi : le 0.5b recommandé hallucine sur les questions
# absentes du corpus (voir tests/resultats_tests.md)
OLLAMA_MODEL=qwen2.5:1.5b

# URL du serveur Ollama (ne pas exposer publiquement)
OLLAMA_URL=http://localhost:11434

# Corpus documentaire
CORPUS_PATH=corpus_de_travail.txt

# Découpage du corpus
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Nombre de segments récupérés par la recherche vectorielle
TOP_K=3

# Timeout de génération (secondes)
LLM_TIMEOUT=120

# Fichier de suivi MLOps
LOG_FILE=logs/queries.jsonl
